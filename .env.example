# Example env file

# Admin seed (used only for initial seeding)
ADMIN_USER=admin
ADMIN_PASSWORD=change_this_password

# JWT
JWT_SECRET=change_this_jwt_secret

# Router HTTP/REST integration
ROUTER_BASE_URL=http://192.168.0.1
ROUTER_USERNAME=routeradmin
ROUTER_PASSWORD=routerpassword

# App
PORT=3000
NODE_ENV=development
